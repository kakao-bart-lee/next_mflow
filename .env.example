# ──────────────────────────────────────────
# 데이터베이스
# ──────────────────────────────────────────
# Docker Compose 사용 시 (make db-up): 포트 5433
DATABASE_URL="postgresql://mflow:mflow_dev_pw@localhost:6532/next_mflow"
# 로컬 PostgreSQL 직접 사용 시:
# DATABASE_URL="postgresql://user:password@localhost:5432/next_mflow"

# ──────────────────────────────────────────
# NextAuth
# ──────────────────────────────────────────
# openssl rand -base64 32
AUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:4830"

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Kakao OAuth (https://developers.kakao.com)
KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""

# 개발 환경: 인증 건너뛰기 (true로 설정하면 dev 계정 자동 로그인)
SKIP_AUTH=false

# ──────────────────────────────────────────
# AI / LLM
# ──────────────────────────────────────────
OPENAI_API_KEY="sk-..."
# 사주 에이전트에 사용할 모델 (기본: gpt-4o-mini)
MASTRA_SAJU_MODEL="gpt-4o-mini"

# ──────────────────────────────────────────
# 기능 플래그
# ──────────────────────────────────────────
# 크레딧 시스템 활성화 (false이면 무제한)
ENABLE_CREDIT_SYSTEM=false
# 구독 시스템 활성화
ENABLE_SUBSCRIPTION_SYSTEM=false
# 신규 가입 무료 크레딧
INITIAL_FREE_CREDITS=10
